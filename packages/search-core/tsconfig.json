{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "../../node_modules/.tmp/tsconfig.search-core.tsbuildinfo",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "baseUrl": "../..",
    "paths": {
      "@njupt-search/contracts": ["packages/contracts/src/index.ts"],
      "@njupt-search/contracts/exam": ["packages/contracts/src/exam/index.ts"],
      "@njupt-search/contracts/search-index": ["packages/contracts/src/search-index/index.ts"],
      "@njupt-search/contracts/source-sitegraph": ["packages/contracts/src/source-sitegraph/index.ts"]
    },
    "noEmit": true
  },
  "include": ["src", "tests", "../contracts/src"]
}
