[{"doc_index":9590,"id":"cxcy-detail-ef0ba62c3288974c7f48","record_type":"detail","page_type":"section_content_page","facet":"notice_article","title":"双创教育","url":"https://cxcy.njupt.edu.cn/15463/list.htm","source_id":"cxcy","source":"创新创业教育学院","source_domain":"cxcy.njupt.edu.cn","section_id":"cxcy_home_link_8f225f64226b","section":"双创教育","nav_path":["首页","双创教育"],"nav_path_text":"首页 / 双创教育","canonical_title":"双创教育","published_at":null,"updated_at":null,"recorded_at":null,"version_date":null,"date_kind":"undated","date_confidence":"unknown","academic_year":null,"term":null,"task_kind":"innovation_entrepreneurship","authority_profile":"cxcy_innovation","dedupe_key":"cxcy:detail:c435921be1408892","publisher":null,"summary":"7月24-26日，中国国际大学生创新大赛（2024）江苏省赛在南京举行，经过激烈争夺，南邮共获得一等奖8项（主赛道6项、红旅1项、产业赛道1项）、二等奖7项、三等奖14项，我校同时获得“优秀组织奖”。 南邮荣获中国国际大学生创新大赛（2024）江苏省决赛一等奖名单 学校一贯重视创新创业教育工作，本次省赛中，创新创业教育学院统筹协调，教务处、学生工作处、团委、","attachment_count":0,"hash":"2c2e03c548ed2eb3e2cf","tags":["homepage_link","notice_article","detail"],"collection_method":"search_record","provenance":{"site_id":"cxcy","section_id":"cxcy_home_link_8f225f64226b","nav_path":["首页","双创教育"],"source_url":"https://cxcy.njupt.edu.cn/15463/list.htm","outcome":"search_record","external_category":null},"content":"7月24-26日，中国国际大学生创新大赛（2024）江苏省赛在南京举行，经过激烈争夺，南邮共获得一等奖8项（主赛道6项、红旅1项、产业赛道1项）、二等奖7项、三等奖14项，我校同时获得“优秀组织奖”。 南邮荣获中国国际大学生创新大赛（2024）江苏省决赛一等奖名单 学校一贯重视创新创业教育工作，本次省赛中，创新创业教育学院统筹协调，教务处、学生工作处、团委、对外联络处、科学技术处、研究生院等多部门通力合作，各学院认真组织广大师生积极参与，我校1148支团队报名、4407人次参赛，项目涉及新工科、新医科、新农科、新文科等多个领域。省赛决赛中，我校参赛选手团结拼搏、勇于争先，展现了敢于创新、善于创新的青春风采，持续擦亮学校“无创新，不南邮”的创新名片。 参赛师生 获奖师生代表 （撰稿：贺超凯、朱转云 初审：张徐 审核：肖建、沈建华）","attachments":[]},{"doc_index":9617,"id":"cxcy-detail-fa6bd26511f2b6e0d847","record_type":"detail","page_type":"section_content_page","facet":"notice_article","title":"立项公示","url":"https://cxcy.njupt.edu.cn/15494/list.htm","source_id":"cxcy","source":"创新创业教育学院","source_domain":"cxcy.njupt.edu.cn","section_id":"cxcy_home_link_754032460167","section":"立项公示","n