[{"doc_index":3700,"id":"jwc-detail-5ace8a9562e8fa7371e3","record_type":"detail","page_type":"detail_article_page","facet":"notice_article","title":"【实践科】2010年美国大学生数学建模竞赛（MCM/ICM）报名通知","url":"https://jwc.njupt.edu.cn/2012/1213/c1594a25535/page.htm","source_id":"jwc","source":"本科生院 / 教务处","source_domain":"jwc.njupt.edu.cn","section_id":"jwc_homepage_notice_module","section":"首页通知公告模块","nav_path":["首页","通知公告"],"nav_path_text":"首页 / 通知公告","canonical_title":"2010年美国大学生数学建模竞赛（MCM/ICM）报名通知","published_at":"2009-12-25","updated_at":null,"recorded_at":null,"version_date":null,"date_kind":"published","date_confidence":"source_published","academic_year":null,"term":null,"task_kind":"innovation_entrepreneurship","authority_profile":"jwc_academic","dedupe_key":"jwc:detail:16d20e34cceb79a4","publisher":"admin","summary":"2010 年美国大学生数学建模竞赛（ MCM/ICM ）报名通知 为了培养学生的创新意识及运用数学方法和计算机技术解决实际问题的能力，同时为了选拨优秀选手参加 2010 年美国大学生数学建模竞赛 （ MCM 和 ICM ）， 现将有关事项通知如下： 一、 美国大学生数学建模竞赛简介 美国大学生数学建模竞赛 （ MCM 和 ICM ），始于 1985 年，主办","attachment_count":0,"hash":"496174b17f54320a6bb8","tags":["notice","homepage_module","notice_article","detail"],"collection_method":"search_record","provenance":{"site_id":"jwc","section_id":"jwc_homepage_notice_module","nav_path":["首页","通知公告"],"source_url":"https://jwc.njupt.edu.cn/2012/1213/c1594a25535/page.htm","outcome":"search_record","external_category":null},"content":"2010 年美国大学生数学建模竞赛（ MCM/ICM ）报名通知 为了培养学生的创新意识及运用数学方法和计算机技术解决实际问题的能力，同时为了选拨优秀选手参加 2010 年美国大学生数学建模竞赛 （ MCM 和 ICM ）， 现将有关事项通知如下： 一、 美国大学生数学建模竞赛简介 美国大学生数学建模竞赛 （ MCM 和 ICM ），始于 1985 年，主办单位为美国运筹学学会、工业与应用数学学会、数学学会、美国国家安全局。其宗旨是鼓励大学生对范围并不固定的各种实际问题予以阐明、分析并提出解法。我校从 2004 年开始参赛，历年来获得一等奖 11 项、二等奖 17 项。下届竞赛将于 2010 年 2 月 18—21 日举行。 二、 报名安排 时间： 2009 年 12 月 31 日 9 ： 00 － 12 ： 00 ； 地点：教 4 五楼西边工程数学教学中心 联系人：孔告化 联系电话： 85866605 三、 参赛资格： 报名参赛学生需具备以下四个条件： 1 、参加过 2009 年全国大学生数学建模竞赛获省级以上奖励的学生 ； 2 、对数学建模竞赛具有极大的兴趣和热情，具有较好的数学基础、熟练的计算机编程能力、具备使用常用软件进行科学计算的能力； 3 、具有较强的英文科技论文阅读和写作能力； 4 、能全程参加集训和辅导，认真坚持，具有较强的创新能力和创新意识及团队合作精神。 四、选拔方式 在自愿报名的基础上，由教练组组织选拔（含面试及模拟竞赛，具体时间另行通知），主要从以下几方面综合考虑： 1、 原则上根据 2009 年全国大学生数学建模竞赛成绩选拔； 2、 是否具有较强的英文科技论文阅读和写作能力； 3、 是否具有较好的数学基础、熟练的计算机编程能力及是否具备使用常用软件进行科学计算的能力。 教务处 理学院 2009 年 12 月 24 日","attachments":[]},{"doc_index":3747,"id":"jwc-detail-b0624c7589bb43e9cbd1","record_type":"detail","page_type":"detail_article_page","facet":"notice_article","title":"【教材科】关于国防工业出版社来我校举办书展的通知","url":"https://jwc.njupt.edu.cn/2012/1213/c1594a25596/page.htm","source_id":"jwc","source":"本科生院 / 教务处","source_domain":"jwc.njupt.edu.cn","section_id":"jwc_homepage_notice_module","section":"首页通知公告模块","nav_path":["首页","通知公告"],"nav_path_text":"首页 / 通知公告","canonical_title":"关于国防工业出版社来我校举办书展的通知","published_at":"2009-10-21","updated_at":null,"recorded_at":null,"version_date":null,"date_kind":"published","date_confidence":"source_published","academic_year":null,"term":null,"task_kind":"broad_exploratory","authority_profile":"jwc_academic","dedupe_key":"jwc:detail:59aac29d778ddf8c","publisher":"admin","summary":"关于国防工业出版社来我校举办书展的通知 国防工业出版社将 于 10 月 27 日（周二）上午 9:00 ～ 11:30 及下午 2:00 ～ 4:30 在我校举办书展，届时将赠送样书和小礼品，书展地点为三牌楼校区教学主楼一楼会议室。 本次书展将展出教材 300 余种，相关院系重点为光电工程学院、通信与信息工程学院、电子科学与工程学院、计算机学院、自动化学院等","attachment_count":0,"hash":"049ac7b95fcb86a7a011","tags":["notice","homepage_module","notice_article","detail"],"collection_method":"search_record","provenance":{"site_id":"jwc","section_id":"jwc_homepage_notice_module","nav_path":["首页","通知公告"],"source_url":"https://jwc.njupt.edu.cn/2012/1213/c1594a25596/page.htm","outcome":"search_record","external_category":null},"content":"关于国防工业出版社来我校举办书展的通知 国防工业出版社将 于 10 月 27 日（周二）上午 9:00 ～ 11:30 及下午 2:00 ～ 4:30 在我校举办书展，届时将赠送样书和小礼品，书展地点为三牌楼校区教学主楼一楼会议室。 本次书展将展出教材 300 余种，相关院系重点为光电工程学院、通信与信息工程学院、电子科学与工程学院、计算机学院、自动化学院等理工学院。书展主要针对 任课 老师，每位老师可以赠送 1 到 2 册本专业的教材。如果老师有教材出版计划，可与编辑咨询出版方面的事宜。 欢迎各位老师光临。 教务处教材科 二〇〇九年十月十九日","attachments":[]},{"doc_index":3757,"id":"jwc-detail-8a0b2ad7117e72ebdff2","record_type":"detail","page_type":"detail_article_page","facet":"notice_article","title":"【教务科】2009-2010-1任选课安