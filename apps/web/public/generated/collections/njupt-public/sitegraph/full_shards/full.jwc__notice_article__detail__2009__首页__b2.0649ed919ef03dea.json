[{"doc_index":3722,"id":"jwc-detail-dcf748c0fa1e7d1e10cf","record_type":"detail","page_type":"detail_article_page","facet":"notice_article","title":"【实践科】我校学生参加“全国大学生数学建模竞赛”获得佳绩","url":"https://jwc.njupt.edu.cn/2012/1213/c1594a25563/page.htm","source_id":"jwc","source":"本科生院 / 教务处","source_domain":"jwc.njupt.edu.cn","section_id":"jwc_homepage_notice_module","section":"首页通知公告模块","nav_path":["首页","通知公告"],"nav_path_text":"首页 / 通知公告","canonical_title":"我校学生参加“全国大学生数学建模竞赛”获得佳绩","published_at":"2009-12-11","updated_at":null,"recorded_at":null,"version_date":null,"date_kind":"published","date_confidence":"source_published","academic_year":null,"term":null,"task_kind":"innovation_entrepreneurship","authority_profile":"jwc_academic","dedupe_key":"jwc:detail:dc842246c5678af9","publisher":"admin","summary":"我校学生参加“全国大学生数学建模竞赛”获得佳绩 全国大学生数学建模竞赛于 2009 年 9 月 11 ～ 14 日举行，我校在校级竞赛的基础上选拔了 48 支代表队参赛， 36 支代表队获奖，其中全国一等奖 3 项，全国二等奖 7 项，省一等奖 11 项，二等奖 5 项，三等奖 10 项，在江苏高校中名列前茅。 本次竞赛江苏赛区共有来自 78 所本科院校的","attachment_count":0,"hash":"a15d53d6f38efd0153ab","tags":["notice","homepage_module","notice_article","detail"],"collection_method":"search_record","provenance":{"site_id":"jwc","section_id":"jwc_homepage_notice_module","nav_path":["首页","通知公告"],"source_url":"https://jwc.njupt.edu.cn/2012/1213/c1594a25563/page.htm","outcome":"search_record","external_category":null},"content":"我校学生参加“全国大学生数学建模竞赛”获得佳绩 全国大学生数学建模竞赛于 2009 年 9 月 11 ～ 14 日举行，我校在校级竞赛的基础上选拔了 48 支代表队参赛， 36 支代表队获奖，其中全国一等奖 3 项，全国二等奖 7 项，省一等奖 11 项，二等奖 5 项，三等奖 10 项，在江苏高校中名列前茅。 本次竞赛江苏赛区共有来自 78 所本科院校的 1036 个代表队参赛。经专家评审、结果公示和竞赛组委会审定，共有 395 队获奖，其中全国一等奖 25 项，全国二等奖 69 项，省一等奖 63 项，省二等奖 92 项，省三等奖 146 项。 全国大学生数学建模竞赛（以下简称竞赛）是教育部高等教育司和中国工业与应用数学学会共同主办的面向全国大学生的群众性科技活动，目的在于激励学生学习数学的积极性，提高学生建立数学模型和运用计算机技术解决实际问题的综合能力，鼓励广大学生踊跃参加课外科技活动，开拓知识面，培养创造精神及合作意识，推动大学数学教学体系、教学内容和方法的改革。本次竞赛旨在促进全省高校大学生科技创新竞赛活动的开展，并为培养学生的科研能力、实践能力和创新精神，提高学生综合素质，为社会输送更多的创新人才。 教务处 理学院 2009 年 12 月 11 日","attachments":[]},{"doc_index":3756,"id":"jwc-detail-26babed014f73fe63adb","record_type":"