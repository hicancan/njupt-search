[{"doc_index":9620,"id":"cxcy-detail-7368465d7f149bc5aed6","record_type":"detail","page_type":"detail_article_page","facet":"notice_article","title":"我校学生在2022年美国大学生数学建模竞赛中获得优异成绩","url":"https://cxcy.njupt.edu.cn/2022/0711/c15496a223922/page.htm","source_id":"cxcy","source":"创新创业教育学院","source_domain":"cxcy.njupt.edu.cn","section_id":"cxcy_home_link_393be12910a3","section":"通讯报道","nav_path":["首页","通讯报道"],"nav_path_text":"首页 / 通讯报道","canonical_title":"我校学生在2022年美国大学生数学建模竞赛中获得优异成绩","published_at":"2022-05-16","updated_at":null,"recorded_at":null,"version_date":null,"date_kind":"published","date_confidence":"source_published","academic_year":null,"term":null,"task_kind":"course_grade_credit","authority_profile":"cxcy_innovation","dedupe_key":"cxcy:detail:db53401dc5b21f0c","publisher":null,"summary":"2022 年美国大学生数学建模竞赛和跨学科建模竞赛结果近日公布，我校组织 265 支队伍参赛，有 121 支代表队共 363 名同学获二等奖及以上奖励 , 其中获特等奖提名奖（ Finalist ） 10 项、一等奖（ Meritorious Winner ） 34 项、二等奖（ Honorable Mention ） 77 项。这是我校自 2004 年参加","attachment_count":0,"hash":"40c23a81444803dc61ad","tags":["homepage_link","notice_article","detail"],"collection_method":"search_record","provenance":{"site_id":"cxcy","section_id":"cxcy_home_link_393be12910a3","nav_path":["首页","通讯报道"],"source_url":"https://cxcy.njupt.edu.cn/2022/0711/c15496a223922/page.htm","outcome":"search_record","external_category":null},"content":"2022 年美国大学生数学建模竞赛和跨学科建模竞赛结果近日公布，我校组织 265 支队伍参赛，有 121 支代表队共 363 名同学获二等奖及以上奖励 , 其中获特等奖提名奖（ Finalist ） 10 项、一等奖（ Meritorious Winner ） 34 项、二等奖（ Honorable Mention ） 77 项。这是我校自 2004 年参加该项赛事以来 , 获得特等奖提名奖、一等奖、二等奖各获奖等级数量均最多的一次。 美国大学生数学建模竞赛 (Mathematical Contest in Modeling ，简称 MCM) 和跨学科建模竞赛 (Interdisciplinary Contest in Modeling ，简称 ICM) 由美国工业与应用数学学会 (SIAM) 于 1985 年创办，此项竞赛在培养学生的创新意识和创造能力以及团队合作意识和团队合作精神方面具有重要的作用，现已发展成为世界上影响范围最大的大学生学科竞赛，也是最著名的国际大学生竞赛之一。","attachments":[]},{"doc_index":9715,"id":"cxcy-detail-90d80df76bad4f3f44bb","record_type":"detail","page_type":"detail_article_page","facet":"notice_article","title":"2022年南京邮电大学创新创业专家大讲堂（