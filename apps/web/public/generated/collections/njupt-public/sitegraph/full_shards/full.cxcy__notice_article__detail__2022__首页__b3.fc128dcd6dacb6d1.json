[{"doc_index":9618,"id":"cxcy-detail-ffc1f9e3430bbab3747f","record_type":"detail","page_type":"detail_article_page","facet":"notice_article","title":"我校学生获第四届“外教社杯”长三角区域高校学生跨文化能力大赛暨全国邀请赛（江苏省赛区）一等奖","url":"https://cxcy.njupt.edu.cn/2022/0711/c15496a223917/page.htm","source_id":"cxcy","source":"创新创业教育学院","source_domain":"cxcy.njupt.edu.cn","section_id":"cxcy_home_link_393be12910a3","section":"通讯报道","nav_path":["首页","通讯报道"],"nav_path_text":"首页 / 通讯报道","canonical_title":"我校学生获第四届“外教社杯”长三角区域高校学生跨文化能力大赛暨全国邀请赛（江苏省赛区）一等奖","published_at":"2022-05-18","updated_at":null,"recorded_at":null,"version_date":null,"date_kind":"published","date_confidence":"source_published","academic_year":null,"term":null,"task_kind":"innovation_entrepreneurship","authority_profile":"cxcy_innovation","dedupe_key":"cxcy:detail:c1e2f60b012a7bd3","publisher":null,"summary":"近日，第四届 “外教社杯”长三角区域高校学生跨文化能力大赛暨全国邀请赛（江苏省赛区）在南京举行。来自省内 60 所高校的 67 支参赛队伍，通过视频投稿的形式参加了本次大赛。经过评审，我校由外国语学院邹静宜同学、刘明同学和电子与光学工程学院沈佳骏同学组成的参赛队伍（指导教师：刘涓涓、杨荔）获得江苏省本科中国学生组一等奖；由海外教育学院三名乌兹别克斯坦籍学生","attachment_count":0,"hash":"e8f40a631434588c77e8","tags":["homepage_link","notice_article","detail"],"collection_method":"search_record","provenance":{"site_id":"cxcy","section_id":"cxcy_home_link_393be12910a3","nav_path":["首页","通讯报道"],"source_url":"https://cxcy.njupt.edu.cn/2022/0711/c15496a223917/page.htm","outcome":"search_record","external_category":null},"content":"近日，第四届 “外教社杯”长三角区域高校学生跨文化能力大赛暨全国邀请赛（江苏省赛区）在南京举行。来自省内 60 所高校的 67 支参赛队伍，通过视频投稿的形式参加了本次大赛。经过评审，我校由外国语学院邹静宜同学、刘明同学和电子与光学工程学院沈佳骏同学组成的参赛队伍（指导教师：刘涓涓、杨荔）获得江苏省本科中国学生组一等奖；由海外教育学院三名乌兹别克斯坦籍学生 Sobirjon Ibragimov, Nodir Izzatullaev 和 Doniyor Jumaniyazov 组成的参赛队伍（指导教师：刘涓涓、王竞雄）获得江苏省国际学生组一等奖。其中，我校获奖的国际学生组将代表江苏晋级全国总决赛。 跨文化能力培养作为一种将语言教学与跨文化教育有机结合的教学理念和模式，是 21 世纪外语教育的重要发展方向，在外语界已经得到广泛认可并被全面推行。“外教社杯”长三角区域高校学生跨文化能力大赛暨全国邀请赛（江苏省赛区）自 2018 年启动以来，已成功举办三届，覆盖全省 100 多所高校，辐射数千名参赛学生。本届江苏省赛区比赛由江苏省高等教育学会指导，江苏省高等学校外国语教学研究会和上海外语教育出版社共同主办，江苏省比较文学学会跨文化研究专业委员会进行学术支持，河海大学外国语学院承办。本次大赛通过赛事平台，以赛促学，增强了不同国籍当代大学生的跨文化意识和交际能力，培养学生从文化差异角度分析问题和解决问题的能力，满足国家和社会对具备国际视野和跨文化能力外语人才的需求，增强了“一带一路”沿线各国人民的人文交流和文化互鉴。","attachments":[]},{"doc_index":9711,"id":"cxcy-detail-0cefbe7d64665c45a4c2","record_type":"detail","page_type":"detail_article_page","facet":"notice_article","title":"2022年南京邮电大学创新创业专家大讲堂（第六期）","url":"https://cxcy.njupt.edu.cn/2022/0712/c15466a224103/page.htm","source_id":"cxcy","source":"创新创业教育学院","source_domain":"cxcy.njupt.edu.cn","section_id":"cxcy_home_link_16eef21a537f","section":"双创活动","nav_path":["首页","双创活动"],"nav_path_text":"首页 / 双创活动","canonical_title":"2022年南京邮电大学创新创业专家大讲堂（第六期）","published_at":"2022-05-18","updated_at":null,"recorded_at":null,"version_date":null,"date_kind":"published","date_confidence":"source_published","academic_year":null,"term":null,"task_kind":"innovation_entrepreneurship","authority_profile":"cxcy_innovation","dedupe_key":"cxcy:detail:c33bd31d874e30c5","publisher":null,"summary":"2022年南京邮电大学创新创业专家大讲堂（第六期）","attachment_count":0,"hash":"7f3bb3bdb8a2d4dd78c2","tags":["homepage_link","notice_article","detail"],"collection_method":"search_record","provenance":{"site_id":"cxcy","section_id":"cxcy_home_link_16eef21a537f","nav_path":["首页","双创活动"],"source_url":"https://cxcy.njupt.edu.cn/2022/0712/c15466a224103/page.htm","outcome":"search_record","external_category":null},"content":"2022年南京邮电大学创新创业专家大讲堂（第六期）","attachments":[]},{"doc_index":9712,"id":"cxcy-detail-44c5d8c3588b794c27f4","record_type":"detail","page_type":"detail_article_page","facet":"notice_article","title":"2022年南京邮电大学创新创业专家大讲堂（第五期）","url":"https://cxcy.njupt.edu.cn/2022/0712/c15466a224102/page.htm","source_id":"cxcy","source":"创新创业教育学院","source_domain":"cxcy.njupt.edu.cn","section_id":"cxcy_home_link_16eef21a537f","section":"双创活动","nav_path":["首页","双创活动"],"nav_path_text":"首页 / 双创活动","canonical_title":"2022年南京邮电大学创新创业专家大讲堂（第五期）","published_at":"2022-05-16","updated_at":null,"recorded_at":null,"version_date":null,"date_kind":"published","date_confidence":"source_published","academic_year":null,"term":null,"