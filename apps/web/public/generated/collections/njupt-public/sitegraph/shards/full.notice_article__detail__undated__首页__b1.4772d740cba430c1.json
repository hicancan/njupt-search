rce_id":"jwc","source":"本科生院 / 教务处","source_domain":"jwc.njupt.edu.cn","section_id":"jwc_home_link_287448874fe6","section":"教学改革","nav_path":["首页","教学改革"],"nav_path_text":"首页 / 教学改革","canonical_title":"教学改革","published_at":null,"updated_at":null,"recorded_at":null,"version_date":null,"date_kind":"undated","date_confidence":"unknown","academic_year":null,"term":null,"task_kind":"broad_exploratory","authority_profile":"jwc_academic","dedupe_key":"jwc:detail:2d1f0f5b04cb25da","publisher":null,"summary":"教学改革","attachment_count":0,"hash":"2d1f0f5b04cb25da6c94","tags":["homepage_link","notice_article","detail"],"collection_method":"search_record","provenance":{"site_id":"jwc","section_id":"jwc_home_link_287448874fe6","nav_path":["首页","教学改革"],"source_url":"https://jwc.njupt.edu.cn/1743/list.htm","outcome":"search_record","external_category":null},"content":"教学改革","attachments":[]},{"doc_index":9575,"id":"cxcy-detail-624600ca9bb13e926c36","record_type":"detail","page_type":"section_content_page","facet":"notice_article","title":"学院概况","url":"https://cxcy.njupt.edu.cn/15461/list.htm","source_id":"cxcy","source":"创新创业教育学院","source_domain":"cxcy.njupt.edu.cn","section_id":"cxcy_home_link_6b7c0aa54912","section":"学院简介","nav_path":["首页","学院简介"],"nav_path_text":"首页 / 学院简介","canonical_title":"学院概况","published_at":null,"updated_at":null,"recorded_at":null,"version_date":null,"date_kind":"undated","date_confidence":"unknown","academic_year":null,"term":null,"task_kind":"innovation_entrepreneurship","authority_profile":"cxcy_innovation","dedupe_key":"cxcy:detail:eaf16fed2b6c44cf","publisher":null,"summary":"南京邮电大学创新创业教育学院成立于 2017 年 9 月，下设 创新创业教育办公室、创新 创业教育中心、创新创业训练中心、创新创业服务中心、江苏省创新创业实践教育中心、 大学生 创新创业协会等机构。 学院以强化学校创新创业教育目的，以服务学生创新创业为导向，通过不断建立、健全先进的教学理念、完备的创新创业教育体系、有效的培训培育方法，积极推进优质资源共享，为","attachment_count":0,"hash":"24bdd0fc341729f927b2","tags":["homepage_link","notice_article","detail"],"collection_method":"search_record","provenance":{"site_id":"cxcy","section_id":"cxcy_home_link_6b7c0aa54912","nav_path":["首页","学院简介"],"source_url":"https://cxcy.njupt.edu.cn/15461/list.htm","outcome":"search_record","external_category":null},"content":"南京邮电大学创新创业教育学院成立于 2017 年 9 月，下设 创新创业教育办公室、创新 创业教育中心、创新创业训练中心、创新创业服务中心、江苏省创新创业实践教育中心、 大学生 创新创业协会等机构。 学院以强化学校创新创业教育目的，以服务学生创新创业为导向，通过不断建立、健全先进的教学理念、完备的创新创业教育体系、有效的培训培育方法，积极推进优质资源共享，为大学生提供多层次、多元化的创新创业实践平台，全面提升大学生创新创业实践能力。 近年来，学校入选“国家创新人才培养示范基地”、“江苏省深化创新创业教育改革示范校”、首批江苏省大学生创新创业实践教育中心。出台《南京邮电大学大学生创新创业竞赛项目认定及分类目录》等文件， 打造了中国国际“互联网 + ”大学生创新创业大赛、全国大学生电子设计竞赛、全国大学生数学建模竞赛、“挑战杯”全国大学生课外学术科技作品竞赛等双创品牌竞赛“一赛一院”机制，不断提升双创教育水平和人才培养质量。学校以校企合作为纽带，通过融入、融通、融合的“三融”机制， 建设了一流教学平台， 构建了产教融合协同育人模式。 截至目前，学校学生在中国国际大学生创新大赛（原中国国际“互联网 + ”大学生创新创业大赛 ） 、全国大学生电子设计竞赛、全国大学生数学建模竞赛、“挑战杯”全国大学生课外学术科技作品竞赛、ACM-ICPC国际大学生程序设计大赛、全国大学生英语竞赛、中国机器人大赛暨 Robocup 公开赛等重大比赛中屡获佳绩， “十三五”以来，本科生共获得国家级及以上奖励 2300 项，省部级奖励 3210 项，其中 2020 年中国国际“互联网 + ”大学生创新创业大赛获金奖 1 项、银奖 2 项、铜奖 1 项，获奖数位居省属高校第一名； 2021 年中国国际“互联网 + ”大学生创新创业大赛全国总决赛获金奖 4 项、银奖 3 项，铜奖 3 项，高教主赛道奖获数位居省属高校第一名，入选排位赛数量和成绩均名列全省第一，同时获得主赛道高校集体奖（全国仅 20 所高校）； 2021 年全国大学生电子设计竞赛取得 10 个国家一等奖， 10 个国家二等奖，总成绩名列全国第二，江苏第一； 2020 年全国大学生数学建模竞赛一等奖 6 项、二等奖 6 项， 第二次获得大满贯（全国第一）； 2019 年全国“挑战杯”大学生课外学术科技作品大赛优胜杯； 2017 年全国大学生电子设计竞赛最高奖瑞萨杯（全国唯一）和 2017 美国大学生数学建模竞赛最高奖 SIAM 奖（全国唯一）。“十三五”以来大学生创新创业训练计划项目共立项 4963 项，其中国家级项目 286 项，省级项目 381 项。","attachments":[]},{"doc_index":9576,"id":"cxcy-detail-57776959a5a1204010d5","record_type":"detail","page_type":"section_content_page","facet":"notice_article","title":"学院概况","url":"https://cxcy.njupt.edu.cn/15485/list.htm","source_id":"cxcy","source":"创新创业教育学院","source_domain":"cxcy.njupt.edu.cn","section_id":"cxcy_home_link_b1e925492719","section":"学院概况","nav_path":["首页","学院概况"],"nav_path_text":"首页 / 学院概况","canonical_title":"学院概况","published_at":null,"updated_at":null,"recorded_at":null,"version_date":null,"date_kind":"undated","date_confidence":"unknown","academic_year":null,"term":null,"task_kind":"innovation_entrepreneurship","authority_profile":"cxcy_innovation","dedupe_key":"cxcy:detail:eaf16fed2b6c44cf","publisher":