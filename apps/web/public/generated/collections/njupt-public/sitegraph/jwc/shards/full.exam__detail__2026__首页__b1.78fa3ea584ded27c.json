bc/1360ded7-d0b3-44d0-92d7-c208d602ab74.doc","extension":"doc","parent_url":"https://jwc.njupt.edu.cn/2026/0228/c1594a297173/page.htm","parent_doc_id":"jwc-detail-4b4848d8b07ed9232390","section_id":"jwc_homepage_notice_module","section":"首页通知公告模块","nav_path":["首页","通知公告"],"metadata_only":true,"position":0}]},{"doc_index":86,"id":"jwc-detail-33ca282025188ba7a9f2","record_type":"detail","page_type":"detail_article_page","facet":"exam","title":"【教务管理办公室】关于2025-2026-2学期补考、缓考成绩录入办法的通知","url":"https://jwc.njupt.edu.cn/2026/0228/c1594a297172/page.htm","source":"本科生院 / 教务处","source_domain":"jwc.njupt.edu.cn","section_id":"jwc_homepage_notice_module","section":"首页通知公告模块","nav_path":["首页","通知公告"],"nav_path_text":"首页 / 通知公告","published_at":"2026-02-28","publisher":"综合办公室","summary":"补考手写成绩登记表.doc","attachment_count":1,"hash":"f1a50484c15de60533ae","tags":["notice","homepage_module","exam","detail"],"collection_method":"search_record","provenance":{"site_id":"jwc","section_id":"jwc_homepage_notice_module","nav_path":["首页","通知公告"],"source_url":"https://jwc.njupt.edu.cn/2026/0228/c1594a297172/page.htm","outcome":"search_record","external_category":null},"content":"补考手写成绩登记表.doc","attachments":[{"attachment_id":"8c9c465fefb487330113","name":"补考手写成绩登记表.doc","url":"https://jwc.njupt.edu.cn/_upload/article/files/7a/58/6665e9bf4a3fa21e92b8781dcb9d/d55ed0af-3ddc-4153-b6dc-31e0559c4c7e.doc","extension":"doc","parent_url":"https://jwc.njupt.edu.cn/2026/0228/c1594a297172/page.htm","parent_doc_id":"jwc-detail-33ca282025188ba7a9f2","section_id":"jwc_homepage_notice_module","section":"首页通知公告模块","nav_path":["首页","通知公告"],"metadata_only":true,"position":0}]},{"doc_index":89,"id":"jwc-detail-b543f3487a91de59d375","record_type":"detail","page_type":"detail_article_page","facet":"exam","title":"【教务管理办公室】关于2022级学生毕业设计（论文）资格审查工作安排的通知","url":"https://jwc.njupt.edu.cn/2026/0227/c1594a297163/page.htm","source":"本科生院 / 教务处","source_domain":"jwc.njupt.edu.cn","section_id":"jwc_homepage_notice_module","section":"首页通知公告模块","nav_path":["首页","通知公告"],"nav_path_text":"首页 / 通知公告","published_at":"2026-02-27","publisher":"综合办公室","summary":"各学院： 按照《南京邮电大学学生学籍管理办法》中的有关规定， 202 2 级学生进入毕业设计（论文）环节前，须对学生的毕业设计（论文）资格进行审查。 为了做好毕业设计（论文）资格审查工作，确保毕业设计（论文）资格审查工作进度，在 3 月 20 日前确定参加毕业设计（论文）学生名单，请各学院严格按照规定时间完成审查工作， 本科生院 审核后将及时公布审查结果。具","attachment_count":4,"hash":"d65cd639d9910342abad","tags":["notice","homepage_module","exam","detail"],"collection_method":"search_record","provenance":{"site_id":"jwc","section_id":"jwc_homepage_notice_module","nav_path":["首页","通知公告"],"source_url":"https://jwc.njupt.edu.cn/2026/0227/c1594a297163/page.htm","outcome":"search_record","external_category":null},"content":"各学院： 按照《南京邮电大学学生学籍管理办法》中的有关规定， 202 2 级学生进入毕业设计（论文）环节前，须对学生的毕业设计（论文）资格进行审查。 为了做好毕业设计（论文）资格审查工作，确保毕业设计（论文）资格审查工作进度，在 3 月 20 日前确定参加毕业设计（论文）学生名单，请各学院严格按照规定时间完成审查工作， 本科生院 审核后将及时公布审查结果。具体要求如下： 一、审查办法 历年取得的必修课与限制性选修课累计学分与所在年级专业培养方案要求完成的总学分差距小于或等于 16 学分者，可以申请进行毕业设计（论文），大于 16 学分者编入下一年级学习。各学院可根据学校总体安排自行确定具体审查过程，并可参考《毕业设计（论文）资格审查说明书》开展审查工作 ， 或者参考上学期毕业预审核的结果并结合上学期学生考试成绩进行审核。 二、时间安排 时 间 内 容 备 注 3 月 16 日 - 17 日 学院按照学籍管理办法，对照专业培养方案严格进行审查 操作办法见毕业设计（论文）资格审查说明书（附件 1 ） 3 月 18 日 学院将审查通过及未通过学生名单报至 本科生院 按附件 2 和 3 格式填写 3 月 19 日 - 20 日 本科生院 复核，与学院确认最终名单并公布 确认的名单由教学院长签字，盖章 三、工作要求 1 ．严格按照培养方案要求进行审查。 2 ．请学院将审查结果通知学生核对，要求学生了解自己所欠学分情况并请学生签名确认；特别是不及格总学分大于 16 的学生，务必请学生签名确认。 3 ．请以学院为单位将审查的结果，即两份名单（不及格学分小于或等于 16 学分可以进行毕业设计（论文）的学生名单和不及格学分大于 16 学分被编入下一年级学习的学生名单）和编入下一年级的学生签名确认的书面材料按照规定的时间报至 本科生院教务管理办公室 。 4 ．为配合做好该项工作，请各学院提醒相关教师尽早提交 202 2 级的补考成绩。 附件1-毕业设计（论文）资格审查说明书.doc 附件2-2022级通过毕业设计（论文）审查学生名单.XLS 附件3-2022级确认编级学生名单.XLS 本科生院 202 6 年 2 月 27 日","attachments":[{"attachment_id":"99c9986b966ca5cae82f","name":"附件1-毕业设计（论文）资格审查说明书.doc","url":"https://jwc.njupt.edu.cn/_upload/article/files/41/f0/e1076046488c9aa99763573f1bfe/99bb758a-1063-404e-8136-dbefe9a02134.doc","extension":"doc","parent_url":"https://jwc.njupt.edu.cn/2026/0227/c1594a297163/page.htm","parent_doc_id":"jwc-detail-b543f3487a91de59d375","section_id":"jwc_homepage_notice_module","section":"首页通知公告模块","nav_path":["首页","通知公告"],"metadata_only":true,"position":0},{"attachment_id":"45d4f1b231ccb1f9262a","name":"99bb758a-1063-404e-8136-dbefe9a02134.doc","url":"https://jwc.njupt.edu.cn/_upload/article/files/41/f0/e1076046488c9aa99763573f1bfe/99bb758a-1063-404e-8136-dbefe9a02134.doc","extension":"doc","parent_url":"https://jwc.njupt.edu.cn/2026/0227/c1594a297163/page.htm","parent_doc_id":"jwc-detail-b543f3487a91de59d375","section_id":"jwc_homepage_notice_module","section":"首页通知公告模块","nav_path":["首页","通知公告"],"metadata_only":true,"position":3},{"attachment_id":"5972f0d767a299a56fd4","name":"附件2-2022级通过毕业设计（论文）审查学生名单.XLS","url":"https://jwc.njupt.edu.cn/_upload/article/files/41/f0/e1076046488c9aa99763573f1bfe/b5aa347d-f1f2-4b80-b42d-06efd8d28ec4.xls","extension":"xls","parent_url":"https://jwc.njupt.edu.cn/2026/0227/c1594a297163/page.htm","parent_doc_id":"jwc-detail-b543f3487a91de59d375","section_id":"jwc_homepage_notice_module","section":"首页通知公告模块","nav_path":["首页","通知公告"],"metadata_only":true,"position":2},{"attachment_id":"b0ef05c862b663ba7984","name":"附件3-2022级确认编级学生名单.XLS","url":"https://jwc.njupt.edu.cn/_upload/article/files/41/f0/e1076046488c9aa99763573f1bfe/ab3ea925-f5f1-4d03-93e2-a68fc5d23247.xls","extension":"xls","parent_url":"https://jwc.njupt.edu.cn/2026/0227/c1594a297163/page.htm","parent_doc_id":"jwc-detail-b543f3487a91de59d375","section_id":"jwc_homepage_notice_module","section":"首页通知公告模块","nav_path":["首页","通知公告"],"metadata_only":true,"position":4}]}]