arent_url":"https://jwc.njupt.edu.cn/2022/0829/c1594a225143/page.htm","parent_doc_id":"jwc-detail-f21065029d3a83c997a8","section_id":"jwc_homepage_notice_module","section":"首页通知公告模块","nav_path":["首页","通知公告"],"metadata_only":true,"position":31},{"attachment_id":"83e97654a7c8023b5a7a","name":"0-关于选派学生参加2023年加拿大阿尔伯塔大学本科生实习奖学金的通知.doc","url":"https://jwc.njupt.edu.cn/_upload/article/files/59/4d/c0f5535b4a20ab5a3a718a447b5b/1fdc9c70-33bd-4572-8788-261ce249a68a.doc","extension":"doc","parent_url":"https://jwc.njupt.edu.cn/2022/0829/c1594a225143/page.htm","parent_doc_id":"jwc-detail-f21065029d3a83c997a8","section_id":"jwc_homepage_notice_module","section":"首页通知公告模块","nav_path":["首页","通知公告"],"metadata_only":true,"position":32},{"attachment_id":"457e8f1d75f98b8e37ed","name":"附件2-南京邮电大学本科生海外访学申请表.doc","url":"https://jwc.njupt.edu.cn/_upload/article/files/59/4d/c0f5535b4a20ab5a3a718a447b5b/7f42bf5b-6876-4331-9a25-7f1962cf7c48.doc","extension":"doc","parent_url":"https://jwc.njupt.edu.cn/2022/0829/c1594a225143/page.htm","parent_doc_id":"jwc-detail-f21065029d3a83c997a8","section_id":"jwc_homepage_notice_module","section":"首页通知公告模块","nav_path":["首页","通知公告"],"metadata_only":true,"position":33},{"attachment_id":"bf631f3d48375b585ab6","name":"附件3-南京邮电大学本科生海外访学申请汇总表.xls","url":"https://jwc.njupt.edu.cn/_upload/article/files/59/4d/c0f5535b4a20ab5a3a718a447b5b/798adb70-6fa4-44c8-b375-8cb517434dda.xls","extension":"xls","parent_url":"https://jwc.njupt.edu.cn/2022/0829/c1594a225143/page.htm","parent_doc_id":"jwc-detail-f21065029d3a83c997a8","section_id":"jwc_homepage_notice_module","section":"首页通知公告模块","nav_path":["首页","通知公告"],"metadata_only":true,"position":34}]},{"doc_index":622,"id":"jwc-detail-949d017034de169be125","record_type":"detail","page_type":"detail_article_page","facet":"workflow","title":"【实践科】关于开展2022年第16届“西门子杯”中国智能制造挑战赛南京邮电大学校内选拔赛的通知","url":"https://jwc.njupt.edu.cn/2022/0525/c1594a221694/page.htm","source":"本科生院 / 教务处","source_domain":"jwc.njupt.edu.cn","section_id":"jwc_homepage_notice_module","section":"首页通知公告模块","nav_path":["首页","通知公告"],"nav_path_text":"首页 / 通知公告","published_at":"2022-05-25","publisher":"陈兴","summary":"“ 西门子杯 ” 中国智能制造挑战赛（以下简称 “ 大赛 ” ）原为全国大学生控制仿真挑战赛、全国大学生工业自动化挑战赛，是教育部与西门子公司战略合作框架下的一项国家级 A 类赛事，是目前国内工业自动化领域规模最大的学生类竞赛之一。 大赛的赛程安排分为 校级竞赛 - 全国初赛 - 全国总决赛 三个阶段，根据竞赛要求并结合我校实际情况研究决定，将于 2022","attachment_count":0,"hash":"c74ef1d49650fcde3eea","tags":["notice","homepage_module","workflow","detail"],"collection_method":"search_record","provenance":{"site_id":"jwc","section_id":"jwc_homepage_notice_module","nav_path":["首页","通知公告"],"source_url":"https://jwc.njupt.edu.cn/2022/0525/c1594a221694/page.htm","outcome":"search_record","external_category":null},"content":"“ 西门子杯 ” 中国智能制造挑战赛（以下简称 “ 大赛 ” ）原为全国大学生控制仿真挑战赛、全国大学生工业自动化挑战赛，是教育部与西门子公司战略合作框架下的一项国家级 A 类赛事，是目前国内工业自动化领域规模最大的学生类竞赛之一。 大赛的赛程安排分为 校级竞赛 - 全国初赛 - 全国总决赛 三个阶段，根据竞赛要求并结合我校实际情况研究决定，将于 2022 年 6 月举行校内选拔赛，由教务处主办，自动化学院、人工智能学院承办，现将竞赛相关事宜通知如下。 一、竞赛目标 大赛以 “ 立足培养，重在参与，面向工程，追求卓越 ” 为指导思想，旨在促进高等学校的工程实践能力教育，提高学生的工程兴趣、工程素养、工程设计能力、实践动手能力、工程创新和工程研发能力，倡导理论联系实际、求真务实的学风和团队协作的人文精神，培养学生的综合知识运用能力，为培养高质量的理工科优秀人才提供实践平台。 二、竞赛内容简介 全国赛项分为“智能制造工程设计与应用类”以及“智能制造创新研发类”两类共包括 8 个赛项，每个赛项的详细题目信息与参考资料可见官网： http://www.siemenscup-cimc.org.cn/ 结合我校实际情况，本次校级竞赛仅组织 离散行业自动化赛项 ： 该赛项面向西门子可编程控制器的基本逻辑控制技术及应用场景，如针对复杂逻辑目标的梳理与实现、电、气动机械装置的基本控制、具有流程性的自动控制系统的设计与实现等。本赛项校级竞赛将通过现场接线、程序编写、操作演示和总结报告多种方式综合考评。 学校将根据校赛的结果推选晋级全国初赛的队伍 。 三、竞赛日程与安排 1. 竞赛报名： 报名截止时间为 2022 年 5 月 26 日 18:00 ，以参赛队为基本单元进行报名，请参赛队在大赛官网注册报名。报名完成后，离散行业自动化赛项成员加 QQ 群 361343811 （以“学号 + 姓名”方式审核进群）。 2. 报名条件： 参赛对象原则上以在校一、二、三年级本科生为主，要求已掌握西门子系列 PLC 的基础知识和编程技能（报名后、校赛前会对参赛选手进行集中培训），或具备智能制造相关技术。 3. 报名组队规则 1) 以参赛队为基本单元，每支队伍由 1-3 名学生和 1-2 名指导教师组成； 2) 参赛学生限在校全日制学生 ( 包括本科生及研究生 ) ，每支队伍最多允许包括 1 名研究生。 4. 校级竞赛时间地点安排 离散行业自动化赛项 将通过现场接线、程序编写、操作演示和总结报告多种方式综合考评，比赛题目及详细内容会提前 2-3 天公布，期间参赛队伍可预约实验设备练习操作。竞赛时间定于 6 月上旬进行（具体时间另行通知）。 5. 竞赛奖励 奖励等级分一等奖、二等奖和三等奖，获奖比例为一等奖 10 ％、二等奖 15 ％、三等奖为 25% （遇非整数向下取整）。 南京邮电大学分赛区将对获奖队伍给予相应奖励与表彰，并从获奖参赛队中择优选拔队伍晋级全国初赛。 教务处、自动化学院、人工智能学院 2022 年 5 月 25 日","attachments":[]}]